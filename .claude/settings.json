{
  "enabledPlugins": {
    "context7@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true
  },
  "permissions": {
    "allow": [
      "Bash(bun *)",
      "Bash(bunx *)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(tail *)",
      "Bash(head *)",
      "Bash(mkdir *)",
      "Bash(cp *)",
      "Bash(wc *)",
      "Bash(for *)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git stash*)",
      "Bash(git pull*)",
      "Bash(git checkout main*)",
      "Bash(git checkout feat/*)",
      "Bash(git checkout fix/*)",
      "Bash(git checkout chore/*)",
      "Bash(git checkout refactor/*)",
      "Bash(git push -u origin *)",
      "Bash(git push origin *)",
      "Bash(git worktree *)",
      "Bash(git rev-parse *)",
      "Bash(git remote prune *)",
      "Bash(git branch -m *)",
      "Bash(which *)",
      "Bash(gh pr view *)",
      "Bash(gh pr create *)",
      "Bash(gh pr merge *)",
      "Bash(gh pr list*)",
      "Bash(gh issue list*)",
      "Bash(gh issue edit *)",
      "Bash(gh issue comment *)",
      "Bash(gh issue close *)",
      "Bash(gh issue create *)",
      "Bash(gh issue view *)",
      "Bash(gh api repos/*)",
      "Bash(gh api graphql *)",
      "Read(**)",
      "Write(**)",
      "Edit(**)"
    ],
    "deny": [
      "Bash(git reset *)",
      "Bash(git clean *)",
      "Bash(git checkout -- *)",
      "Bash(git checkout .*)",
      "Bash(git checkout -b *)",
      "Bash(git push --force*)",
      "Bash(git push * --force*)",
      "Bash(git rebase *)",
      "Bash(git branch -D *)",
      "Bash(git branch -d *)",
      "Bash(npx *)",
      "Bash(npm *)",
      "Bash(node *)",
      "Bash(gh repo delete*)",
      "Bash(gh pr merge * --admin*)",
      "Bash(gh pr merge --admin*)",
      "Bash(gh pr merge * --auto*)",
      "Bash(gh pr merge --auto*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "resume|compact",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/session-start.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(git checkout -b *)",
            "command": "echo 'BLOCKED: Use git worktree add instead of git checkout -b.' >&2; exit 2",
            "timeout": 5,
            "statusMessage": "Checking branch safety..."
          },
          {
            "type": "command",
            "if": "Bash(npx *)",
            "command": "echo 'BLOCKED: Use bunx instead of npx.' >&2; exit 2",
            "timeout": 5
          },
          {
            "type": "command",
            "if": "Bash(npm *)",
            "command": "echo 'BLOCKED: Use bun instead of npm.' >&2; exit 2",
            "timeout": 5
          },
          {
            "type": "command",
            "if": "Bash(node *)",
            "command": "echo 'BLOCKED: Use bun instead of node.' >&2; exit 2",
            "timeout": 5
          },
          {
            "type": "command",
            "if": "Bash(git commit*)",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/pre-commit.sh",
            "timeout": 5,
            "statusMessage": "Checking quality gates..."
          },
          {
            "type": "command",
            "if": "Bash(gh pr create*)",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/pre-pr.sh",
            "timeout": 5,
            "statusMessage": "Checking cross-model review..."
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "INPUT=$(cat); LINES=$(echo \"$INPUT\" | jq -r '.tool_input.content // \"\"' 2>/dev/null | wc -l | tr -d ' '); if [ \"${LINES:-0}\" -gt 500 ]; then echo \"BLOCKED: File would be $LINES lines (limit: 500). Split by responsibility.\" >&2; exit 2; fi",
            "timeout": 10,
            "statusMessage": "Checking file size..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(bun run check*)",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/post-quality-gate.sh check_passed",
            "timeout": 5
          },
          {
            "type": "command",
            "if": "Bash(bun run typecheck*)",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/post-quality-gate.sh typecheck_passed",
            "timeout": 5
          },
          {
            "type": "command",
            "if": "Bash(bun test*)",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/post-quality-gate.sh tests_passed",
            "timeout": 5
          },
          {
            "type": "command",
            "if": "Bash(git commit*)",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/post-commit.sh",
            "statusMessage": "Checking changeset need..."
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bunx @biomejs/biome check --write \"$CLAUDE_FILE_PATH\" 2>/dev/null || true",
            "statusMessage": "Auto-formatting..."
          },
          {
            "type": "command",
            "command": "LINES=$(wc -l < \"$CLAUDE_FILE_PATH\" 2>/dev/null | tr -d ' '); if [ \"${LINES:-0}\" -gt 500 ]; then echo \"WARNING: $CLAUDE_FILE_PATH is now $LINES lines (limit: 500). Consider splitting.\"; fi",
            "timeout": 5,
            "statusMessage": "Checking file size..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/stop-check.sh"
          }
        ]
      }
    ]
  }
}
