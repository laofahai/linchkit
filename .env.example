# AI Provider secrets — referenced from linchkit.config.ts via $env.VAR_NAME
# Add entries here for each provider configured in your linchkit.config.ts
# Example: apiKey: "$env.ANTHROPIC_API_KEY" in config reads from here
ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# DEEPSEEK_API_KEY=sk-...
# DEEPSEEK_ENDPOINT=https://api.deepseek.com/v1
# VOLCENGINE_API_KEY=sk-...

# Database — when set, PostgreSQL is used instead of InMemoryStore
# DATABASE_URL=postgres://linchkit:linchkit@localhost:5432/linchkit

# Test database (used by integration tests)
DATABASE_TEST_URL=postgres://linchkit_test:linchkit_test@localhost:5434/linchkit_test

# GitHub Integration (M1+)
# GITHUB_TOKEN=ghp_...
