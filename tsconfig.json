{
  "compilerOptions": {
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "jsx": "react-jsx",
    "types": ["bun-types"],
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "composite": true,
    "paths": {
      "@linchkit/core": ["./packages/core/src"],
      "@linchkit/core/types": ["./packages/core/src/types-entry.ts"],
      "@linchkit/core/define": ["./packages/core/src/define-entry.ts"],
      "@linchkit/core/server": ["./packages/core/src/server-entry.ts"],
      "@linchkit/core/config": ["./packages/core/src/config/index.ts"],
      "@linchkit/core/utils/env": ["./packages/core/src/utils/env.ts"],
      "@linchkit/cli": ["./packages/cli/src"],
      "@linchkit/devtools": ["./packages/devtools/src"],
      "@linchkit/cap-adapter-server": ["./addons/adapter-server/cap-adapter-server/src"],
      "@linchkit/cap-adapter-server/capability": [
        "./addons/adapter-server/cap-adapter-server/src/capability.ts"
      ],
      "@linchkit/cap-adapter-ui-react": ["./addons/adapter-ui-react/cap-adapter-ui-react/src"],
      "@linchkit/cap-adapter-ui-react/capability": [
        "./addons/adapter-ui-react/cap-adapter-ui-react/src/capability.ts"
      ],
      "@linchkit/cap-adapter-ui-react/panel-registry": [
        "./addons/adapter-ui-react/cap-adapter-ui-react/src/lib/panel-registry.ts"
      ],
      "@linchkit/cap-adapter-ui-react/hooks/use-subscription": [
        "./addons/adapter-ui-react/cap-adapter-ui-react/src/hooks/use-subscription.ts"
      ],
      "@linchkit/cap-adapter-ui-react/lib/api": [
        "./addons/adapter-ui-react/cap-adapter-ui-react/src/lib/api.ts"
      ],
      "@linchkit/cap-adapter-mcp": ["./addons/adapter-mcp/cap-adapter-mcp/src"],
      "@linchkit/cap-auth": ["./addons/auth/cap-auth/src"],
      "@linchkit/cap-auth/ui": ["./addons/auth/cap-auth/ui/index.ts"],
      "@linchkit/cap-permission": ["./addons/permission/cap-permission/src"],
      "@linchkit/ui-kit": ["./addons/adapter-ui-react/cap-adapter-ui-react/ui-kit/src"],
      "@linchkit/ui-kit/components": ["./addons/adapter-ui-react/cap-adapter-ui-react/ui-kit/src/components"],
      "@linchkit/ui-kit/hooks": ["./addons/adapter-ui-react/cap-adapter-ui-react/ui-kit/src/hooks"],
      "@linchkit/ui-kit/lib/utils": ["./addons/adapter-ui-react/cap-adapter-ui-react/ui-kit/src/lib/utils"],
      "@linchkit/cap-purchase-demo": ["./addons/demo/cap-purchase-demo/src"],
      "@linchkit/cap-ui-react-chatter": ["./addons/chatter/cap-ui-react-chatter/src"],
      "@linchkit/cap-chatter": ["./addons/chatter/cap-chatter/src"],
      "@linchkit/cap-chatter/capability": ["./addons/chatter/cap-chatter/src/capability.ts"],
      "@linchkit/cap-chatter/graphql": ["./addons/chatter/cap-chatter/src/graphql.ts"],
      "@/*": ["./addons/adapter-ui-react/cap-adapter-ui-react/src/*"]
    }
  },
  "include": [
    "config/**/*.ts",
    "packages/*/src/**/*.ts",
    "packages/*/src/**/*.tsx",
    "packages/*/ui/**/*.ts",
    "packages/*/ui/**/*.tsx",
    "addons/*/cap-*/src/**/*.ts",
    "addons/*/cap-*/src/**/*.tsx",
    "addons/*/cap-*/ui/**/*.ts",
    "addons/*/cap-*/ui/**/*.tsx",
    "addons/*/cap-*/ui-kit/src/**/*.ts",
    "addons/*/cap-*/ui-kit/src/**/*.tsx",
    "e2e/**/*.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
