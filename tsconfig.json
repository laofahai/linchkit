{
  "compilerOptions": {
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "jsx": "react-jsx",
    "types": ["bun-types"],
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "composite": true,
    "paths": {
      "@linchkit/core": ["./packages/core/src"],
      "@linchkit/core/types": ["./packages/core/src/types-entry.ts"],
      "@linchkit/core/define": ["./packages/core/src/define-entry.ts"],
      "@linchkit/core/server": ["./packages/core/src/server-entry.ts"],
      "@linchkit/core/config": ["./packages/core/src/config/index.ts"],
      "@linchkit/core/utils/env": ["./packages/core/src/utils/env.ts"],
      "@linchkit/core/ai": ["./packages/core/src/ai/index.ts"],
      "@linchkit/cli": ["./packages/cli/src"],
      "@linchkit/devtools": ["./packages/devtools/src"],
      "@linchkit/devtools/documentation": ["./packages/devtools/src/documentation/index.ts"],
      "@linchkit/devtools/methodology": ["./packages/devtools/src/methodology/index.ts"],
      "@linchkit/devtools/governance": ["./packages/devtools/src/governance/index.ts"],
      "@linchkit/cap-adapter-server": ["./addons/adapter-server/cap-adapter-server/src"],
      "@linchkit/cap-adapter-server/capability": [
        "./addons/adapter-server/cap-adapter-server/src/capability.ts"
      ],
      "@linchkit/cap-adapter-ui": ["./addons/adapter-ui/cap-adapter-ui/src"],
      "@linchkit/cap-adapter-ui/capability": [
        "./addons/adapter-ui/cap-adapter-ui/src/capability.ts"
      ],
      "@linchkit/cap-adapter-ui/panel-registry": [
        "./addons/adapter-ui/cap-adapter-ui/src/lib/panel-registry.ts"
      ],
      "@linchkit/cap-adapter-ui/hooks/use-subscription": [
        "./addons/adapter-ui/cap-adapter-ui/src/hooks/use-subscription.ts"
      ],
      "@linchkit/cap-adapter-ui/lib/api": ["./addons/adapter-ui/cap-adapter-ui/src/lib/api.ts"],
      "@linchkit/cap-ai-provider": ["./addons/ai-provider/cap-ai-provider/src"],
      "@linchkit/cap-adapter-mcp": ["./addons/adapter-mcp/cap-adapter-mcp/src"],
      "@linchkit/cap-auth": ["./addons/auth/cap-auth/src"],
      "@linchkit/cap-auth/ui": ["./addons/auth/cap-auth/ui/index.ts"],
      "@linchkit/cap-permission": ["./addons/permission/cap-permission/src"],
      "@linchkit/ui-kit": ["./addons/adapter-ui/cap-adapter-ui/ui-kit/src"],
      "@linchkit/ui-kit/components": ["./addons/adapter-ui/cap-adapter-ui/ui-kit/src/components"],
      "@linchkit/ui-kit/hooks": ["./addons/adapter-ui/cap-adapter-ui/ui-kit/src/hooks"],
      "@linchkit/ui-kit/lib/utils": ["./addons/adapter-ui/cap-adapter-ui/ui-kit/src/lib/utils"],
      "@linchkit/cap-purchase-demo": ["./addons/demo/cap-purchase-demo/src"],
      "@linchkit/cap-life-demo": ["./addons/demo/cap-life-demo/src"],
      "@linchkit/cap-chatter-ui": ["./addons/chatter/cap-chatter-ui/src"],
      "@linchkit/cap-chatter": ["./addons/chatter/cap-chatter/src"],
      "@linchkit/cap-chatter/capability": ["./addons/chatter/cap-chatter/src/capability.ts"],
      "@linchkit/cap-chatter/graphql": ["./addons/chatter/cap-chatter/src/graphql.ts"],
      "@linchkit/cap-search": ["./addons/search/cap-search/src"],
      "@linchkit/cap-search/capability": ["./addons/search/cap-search/src/capability.ts"],
      "@linchkit/cap-search/graphql": ["./addons/search/cap-search/src/graphql.ts"],
      "@linchkit/cap-cache-redis": ["./addons/cache-redis/cap-cache-redis/src"],
      "@linchkit/cap-cache-redis/capability": [
        "./addons/cache-redis/cap-cache-redis/src/capability.ts"
      ],
      "@/*": ["./addons/adapter-ui/cap-adapter-ui/src/*"]
    }
  },
  "include": [
    "config/**/*.ts",
    "packages/*/src/**/*.ts",
    "packages/*/src/**/*.tsx",
    "packages/*/ui/**/*.ts",
    "packages/*/ui/**/*.tsx",
    "addons/*/cap-*/src/**/*.ts",
    "addons/*/cap-*/src/**/*.tsx",
    "addons/*/cap-*/ui/**/*.ts",
    "addons/*/cap-*/ui/**/*.tsx",
    "addons/*/cap-*/ui-kit/src/**/*.ts",
    "addons/*/cap-*/ui-kit/src/**/*.tsx",
    "addons/*/cap-*/eval-runner/**/*.ts",
    "addons/*/cap-*/__tests__/eval-runner/**/*.ts",
    "e2e/**/*.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
