{
  "compilerOptions": {
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "jsx": "react-jsx",
    "types": ["bun-types"],
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "composite": true,
    "paths": {
      "@linchkit/core": ["./packages/core/src"],
      "@linchkit/core/types": ["./packages/core/src/types-entry.ts"],
      "@linchkit/core/define": ["./packages/core/src/define-entry.ts"],
      "@linchkit/core/server": ["./packages/core/src/server-entry.ts"],
      "@linchkit/cli": ["./packages/cli/src"],
      "@linchkit/devtools": ["./packages/devtools/src"],
      "@linchkit/cap-adapter-server": ["./capabilities/cap-adapter-server/src"],
      "@linchkit/cap-adapter-server/capability": [
        "./capabilities/cap-adapter-server/src/capability.ts"
      ],
      "@linchkit/cap-adapter-ui-react": ["./capabilities/cap-adapter-ui-react/src"],
      "@linchkit/cap-adapter-ui-react/capability": [
        "./capabilities/cap-adapter-ui-react/src/capability.ts"
      ],
      "@linchkit/cap-adapter-mcp": ["./capabilities/cap-adapter-mcp/src"],
      "@linchkit/cap-auth": ["./capabilities/cap-auth/src"],
      "@linchkit/cap-auth/ui": ["./capabilities/cap-auth/ui/index.ts"],
      "@linchkit/cap-permission": ["./capabilities/cap-permission/src"],
      "@linchkit/ui-kit": ["./capabilities/cap-adapter-ui-react/ui-kit/src"],
      "@linchkit/ui-kit/components": ["./capabilities/cap-adapter-ui-react/ui-kit/src/components"],
      "@linchkit/ui-kit/hooks": ["./capabilities/cap-adapter-ui-react/ui-kit/src/hooks"],
      "@linchkit/ui-kit/lib/utils": ["./capabilities/cap-adapter-ui-react/ui-kit/src/lib/utils"],
      "@linchkit/cap-purchase-demo": ["./capabilities/cap-purchase-demo/src"],
      "@linchkit/cap-chatter": ["./capabilities/cap-chatter/src"],
      "@linchkit/cap-chatter/capability": ["./capabilities/cap-chatter/src/capability.ts"],
      "@linchkit/cap-chatter/graphql": ["./capabilities/cap-chatter/src/graphql.ts"],
      "@/*": ["./capabilities/cap-adapter-ui-react/src/*"]
    }
  },
  "include": [
    "config/**/*.ts",
    "packages/*/src/**/*.ts",
    "packages/*/src/**/*.tsx",
    "packages/*/ui/**/*.ts",
    "packages/*/ui/**/*.tsx",
    "capabilities/*/src/**/*.ts",
    "capabilities/*/src/**/*.tsx",
    "capabilities/*/ui/**/*.ts",
    "capabilities/*/ui/**/*.tsx",
    "capabilities/*/ui-kit/src/**/*.ts",
    "capabilities/*/ui-kit/src/**/*.tsx",
    "e2e/**/*.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
