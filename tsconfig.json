{
  "compilerOptions": {
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "jsx": "react-jsx",
    "types": ["bun-types"],
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "composite": true,
    "paths": {
      "@linchkit/core": ["./packages/core/src"],
      "@linchkit/cli": ["./packages/cli/src"],
      "@linchkit/cap-auth": ["./packages/cap-auth/src"],
      "@linchkit/cap-auth/ui": ["./packages/cap-auth/ui/index.ts"],
      "@linchkit/cap-permission": ["./packages/cap-permission/src"],
      "@linchkit/server": ["./packages/server/src"],
      "@linchkit/mcp": ["./packages/mcp/src"],
      "@linchkit/ui": ["./packages/ui/src"],
      "@linchkit/ui-kit": ["./packages/ui-kit/src"],
      "@linchkit/ui-kit/components": ["./packages/ui-kit/src/components"],
      "@linchkit/ui-kit/hooks": ["./packages/ui-kit/src/hooks"],
      "@linchkit/ui-kit/lib/utils": ["./packages/ui-kit/src/lib/utils"],
      "@linchkit/migrate": ["./packages/migrate/src"],
      "@linchkit/devtools": ["./packages/devtools/src"],
      "@/*": ["./packages/ui/src/*"]
    }
  },
  "include": [
    "linchkit.config.ts",
    "packages/*/src/**/*.ts",
    "packages/*/src/**/*.tsx",
    "packages/*/ui/**/*.ts",
    "packages/*/ui/**/*.tsx",
    "e2e/**/*.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
