{
  "id": "we-nf-5",
  "scenario": "watcher-engine",
  "tags": ["not-fired", "threshold", "field-missing"],
  "description": "Threshold watcher on field='nonexistent' which is absent from record — engine cannot evaluate, watcher does NOT fire",
  "input": {
    "entityName": "order",
    "record": { "id": "rec-24", "amount": 800, "status": "active" },
    "oldRecord": { "id": "rec-24", "amount": 500, "status": "draft" },
    "watchers": [
      {
        "name": "missing-field-threshold",
        "label": "Missing Field Threshold",
        "enabled": true,
        "watch": { "entity": "order" },
        "trigger": {
          "type": "threshold",
          "field": "nonexistent",
          "condition": { "gt": 0 }
        },
        "effect": { "action": "notify_team", "params": {} }
      }
    ]
  },
  "context": {},
  "expected": {
    "matchers": [
      { "name": "watcher_not_fired", "args": { "watcherName": "missing-field-threshold" } },
      { "name": "watcher_fire_count", "args": { "value": 0 } }
    ]
  }
}
