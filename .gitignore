# Dependencies
# No trailing slash so a `node_modules` SYMLINK (used in git worktrees to share
# the main checkout's deps) is ignored too — a dir-only `node_modules/` pattern
# does not match a symlink and lets `git add -A` track a machine-local path.
node_modules
bun.lockb

# Build
dist/
*.tsbuildinfo
.vite/
# Stray declaration files generated by tsc in source dirs
packages/*/src/**/*.d.ts
addons/*/cap-*/src/**/*.d.ts

# Environment
.env
.env.*
!.env.example
!.env.production.example

# IDE
.vscode/
.idea/
.serena/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# MCP (contains API keys)
.mcp.json

# Claude local settings (user-specific)
.claude/settings.local.json
.claude/projects/
.claude/scheduled_tasks.lock

# Test
coverage/

# Temp
*.tmp
*.log

# Generated by linch CLI
.linchkit/

# Superpowers (Claude Code skill files)
superpowers/

# Overstory worktrees (dynamic agent workspaces)
.overstory/worktrees/
.claude/worktrees/
worktrees/

# Generated docs snapshot (linch docs output)
docs/generated/
