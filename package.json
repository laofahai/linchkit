{
  "name": "linchkit",
  "private": true,
  "workspaces": [
    "packages/*",
    "packages/starters/*",
    "addons/*/cap-*",
    "addons/adapter-ui/cap-adapter-ui/ui-kit"
  ],
  "scripts": {
    "ai:eval": "bun addons/ai-provider/cap-ai-provider/bin/ai-eval.ts",
    "check": "biome check .",
    "format": "biome format --write .",
    "lint": "biome lint .",
    "typecheck": "bunx tsc --noEmit",
    "test": "bash scripts/run-tests.sh",
    "test:coverage": "bash scripts/verify-test-coverage.sh",
    "test:e2e": "bash scripts/run-e2e-browser.sh",
    "build": "bun run --filter '@linchkit/core' build && bun run --filter '@linchkit/devtools' build && bun run --filter '@linchkit/cli' --filter '@linchkit/cap-adapter-ui' build",
    "dev": "bun run --filter '@linchkit/cap-adapter-server' --filter '@linchkit/cap-adapter-ui' dev",
    "dev:server": "bun run --filter @linchkit/cap-adapter-server dev",
    "dev:ui": "bun run --filter @linchkit/cap-adapter-ui dev",
    "db:generate": "bun ./packages/cli/src/index.ts db generate",
    "db:migrate": "bun ./node_modules/.bin/drizzle-kit migrate",
    "db:studio": "bun ./node_modules/.bin/drizzle-kit studio",
    "changeset": "bunx changeset",
    "version-packages": "bunx changeset version && bun scripts/sync-core-version.ts",
    "sync-core-version": "bun scripts/sync-core-version.ts",
    "release": "bun scripts/release.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@changesets/cli": "^2.31.0",
    "bun-types": "latest",
    "drizzle-kit": "^0.31.10",
    "puppeteer-core": "^25.1.0",
    "tsup": "^8.5.1"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.82",
    "@ai-sdk/openai": "^3.0.69",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@modelcontextprotocol/sdk": "1.29.0",
    "@restatedev/restate-sdk": "1.15.1",
    "@tanstack/react-table": "^8.21.3",
    "ai": "^6.0.199",
    "dataloader": "^2.2.3",
    "drizzle-orm": "^0.45.2",
    "mermaid": "^11.15.0",
    "sonner": "^2.0.7"
  }
}
