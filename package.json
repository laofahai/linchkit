{
  "name": "linchkit",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "check": "bunx @biomejs/biome check .",
    "format": "bunx @biomejs/biome format --write .",
    "lint": "bunx @biomejs/biome lint .",
    "typecheck": "bunx tsc --noEmit",
    "test": "bun test",
    "build": "bun run --filter '*' build",
    "dev": "bun run --filter @linchkit/server dev"
  },
  "devDependencies": {
    "bun-types": "latest"
  }
}
